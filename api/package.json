{
  "name": "api",
  "version": "1.0.0",
  "description": "Hono API backend for query execution",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm run lint && pnpm exec tsc -p tsconfig.build.json && copyfiles -u 1 'src/**/*.svg' dist",
    "start": "tsx src/index.ts",
    "sync": "tsx src/sync/cli.ts",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "migrate:workspaces": "tsx src/migrations/migrate-to-workspaces.ts",
    "lint": "eslint . --ext ts --report-unused-disable-directives",
    "lint:fix": "eslint . --ext ts --fix"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.80",
    "@clickhouse/client": "^1.14.0",
    "@duckdb/node-api": "1.5.0-r.1",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/cloud-sql-connector": "^1.8.4",
    "@google-cloud/storage": "^7.19.0",
    "@hono/node-server": "^1.14.4",
    "@logtape/logtape": "^1.0.4",
    "@mako/schemas": "workspace:*",
    "ai": "6.0.0-beta.166",
    "apache-arrow": "^21.1.0",
    "arctic": "^3.7.0",
    "axios": "^1.6.2",
    "bcrypt": "^6.0.0",
    "commander": "^14.0.0",
    "cors": "^2.8.5",
    "cron-parser": "^5.3.0",
    "diff": "^9.0.0",
    "dotenv": "^16.5.0",
    "express-rate-limit": "^7.5.0",
    "google-auth-library": "^10.4.0",
    "hono": "^4.7.11",
    "inngest": "^3.54.1",
    "inquirer": "^8.2.6",
    "js-yaml": "^4.1.0",
    "mongodb": "^6.17.0",
    "mongoose": "^8.15.1",
    "mssql": "^11.0.1",
    "mysql2": "^3.14.1",
    "nanoid": "^5.1.7",
    "openai": "^5.2.0",
    "parquet-wasm": "^0.7.1",
    "pg": "^8.16.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ssh2": "^1.17.0",
    "stripe": "^14.25.0",
    "uuid": "^9.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/diff": "^8.0.0",
    "@types/inquirer": "^8.2.11",
    "@types/js-yaml": "^4.0.9",
    "@types/mssql": "^9.1.7",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.4",
    "@types/ssh2": "^1.15.5",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^8.34.0",
    "@typescript-eslint/parser": "^8.34.0",
    "copyfiles": "^2.4.1",
    "eslint": "^8.57.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

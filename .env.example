# Application Database
DATABASE_URL=mongodb://localhost:27017/myapp

# Encryption key for sensitive data (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# MongoDB Atlas Password (referenced in config.yaml)
MONGO_ATLAS_PASSWORD=your-atlas-password-here

# Close.com API Keys
CLOSE_API_KEY_SWITZERLAND=your-close-api-key-ch
CLOSE_API_KEY_ITALY=your-close-api-key-it
CLOSE_API_KEY_FRANCE=your-close-api-key-fr
CLOSE_API_KEY_SPAIN=your-close-api-key-es

# Stripe API Keys
STRIPE_API_KEY_SPAIN=your-stripe-api-key-es

# RealAdvisor GraphQL
REALADVISOR_HASURA_SECRET=your-hasura-secret

# OAuth Providers (for authentication)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GH_CLIENT_ID=your-github-client-id
GH_CLIENT_SECRET=your-github-client-secret

# Session Configuration
SESSION_SECRET=your-session-secret

# Application URLs
PUBLIC_URL=http://localhost:5173
API_URL=http://localhost:3000
BASE_URL=http://localhost:8080
CLIENT_URL=http://localhost:5173

# OAuth Proxy (for non-production environments: localhost, PR previews)
# Set PRODUCTION_URL to the production API origin so OAuth callbacks
# route through production. Leave unset in production itself.
# PRODUCTION_URL=https://app.mako.co
# Comma-separated list of additional trusted origins for OAuth redirects
# TRUSTED_ORIGINS=https://my-preview.vercel.app

# Node Environment
NODE_ENV=development

# Optional: bcrypt rounds for password hashing
BCRYPT_ROUNDS=10

# Optional: MongoDB connection options
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=2

# Port Configuration
WEB_API_PORT=8080

# Dashboard Materialization (optional - defaults to filesystem)
# For local GCS materialization, use a service-account credential file because
# signed URL generation requires credentials with a private key.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/dev-service-account.json
# DASHBOARD_ARTIFACT_STORE=gcs
# GCS_DASHBOARD_BUCKET=revops-462013-dashboard-artifacts
# DASHBOARD_ARTIFACT_PREFIX=dashboard-artifacts/local-yourname

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=5

# Inngest
INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key
# Optional for non-production branch deployments
# INNGEST_ENV=pr-123
# INNGEST_SERVE_ORIGIN=http://localhost:8080
# DISABLE_SCHEDULED_SYNC=false
# Max in-flight non-CDC webhook SQL processors per flow (default 5)
# WEBHOOK_SQL_PROCESS_CONCURRENCY=5
# Max in-flight CDC materializations globally (caps BigQuery slot pressure, default 8)
# CDC_MATERIALIZE_CONCURRENCY=8
# Max in-flight CDC materializations per flow (prevents one flow from starving others, default 3)
# CDC_MATERIALIZE_CONCURRENCY_PER_FLOW=3
# Max wait for a single BigQuery MERGE job in CDC materialization, in ms (default 900000 = 15min)
# BIGQUERY_MERGE_MAX_WAIT_MS=900000

# Vercel AI Gateway (REQUIRED for all AI features)
# Generate a key at: Vercel Dashboard > AI Gateway settings
AI_GATEWAY_API_KEY=your_vercel_ai_gateway_key

# Optional: Embeddings only (text-embedding-3-small via raw OpenAI SDK)
OPENAI_API_KEY=your-openai-api-key

# SendGrid Email Service (for invitations and verification)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_INVITATION_TEMPLATE_ID=d-xxxxx  # Optional: Dynamic template ID
SENDGRID_VERIFICATION_TEMPLATE_ID=d-xxxxx  # Optional: Dynamic template ID

# Logo shown at the top of run-notification emails. Defaults to the PNG hosted
# at https://app.mako.ai/email/mako-logo.png (served from app/public/email/).
# Override for self-hosted deploys or staging where app.mako.ai isn't reachable.
# EMAIL_LOGO_URL=https://your-app-domain.example.com/email/mako-logo.png

# Billing / Subscription (optional — off by default for self-hosted)
# Set BILLING_ENABLED=true to activate usage gating and Stripe integration.
# When false (default), all users get unlimited access to all models.
BILLING_ENABLED=false
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRO_PRICE_ID=price_xxx       # Stripe Price ID for the Pro monthly subscription
STRIPE_METER_EVENT_NAME=llm_usage_usd  # Legacy Stripe meter event name; payload value is still sent in cents

# Super admin allow-list (optional)
# Comma-separated email addresses that unlock the cross-workspace "Super Admin"
# settings panel (model catalog curation, platform defaults). Leave unset in
# production to disable super-admin powers entirely.
SUPER_ADMIN_EMAILS=
